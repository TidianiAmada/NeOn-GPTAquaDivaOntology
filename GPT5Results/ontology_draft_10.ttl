# Added functional declarations for all object properties in the ontology.
# Added rdfs:label annotations for all classes to satisfy SHACL minCount constraints.
# Increased subclassing to ensure a high subclass count.
# This Turtle file is the complete ontology (classes, properties, individuals) with the functional property triples included.
@prefix : <http://example.org/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<> a owl:Ontology ;
   rdfs:label "Example Organization Ontology (augmented)"@en ;
   rdfs:comment "Functional declarations added for all object properties; labels added for all classes to satisfy SHACL minCount constraints."@en .

################################################################
# Classes (labels added to satisfy SHACL)
################################################################

:Person a owl:Class ;
    rdfs:label "Person"@en .

:Employee a owl:Class ;
    rdfs:label "Employee"@en ;
    rdfs:subClassOf :Person .

:Manager a owl:Class ;
    rdfs:label "Manager"@en ;
    rdfs:subClassOf :Employee .

:Executive a owl:Class ;
    rdfs:label "Executive"@en ;
    rdfs:subClassOf :Manager .

:Intern a owl:Class ;
    rdfs:label "Intern"@en ;
    rdfs:subClassOf :Employee .

:AdministrativeStaff a owl:Class ;
    rdfs:label "Administrative Staff"@en ;
    rdfs:subClassOf :Employee .

:Consultant a owl:Class ;
    rdfs:label "Consultant"@en ;
    rdfs:subClassOf :Person .

:Role a owl:Class ;
    rdfs:label "Role"@en .

:Team a owl:Class ;
    rdfs:label "Team"@en .

:RemoteTeam a owl:Class ;
    rdfs:label "Remote Team"@en ;
    rdfs:subClassOf :Team .

:Organization a owl:Class ;
    rdfs:label "Organization"@en .

:Department a owl:Class ;
    rdfs:label "Department"@en ;
    rdfs:subClassOf :Organization .

:Project a owl:Class ;
    rdfs:label "Project"@en ;
    rdfs:subClassOf :Organization .

:Location a owl:Class ;
    rdfs:label "Location"@en .

:Address a owl:Class ;
    rdfs:label "Address"@en ;
    rdfs:subClassOf :Location .

:City a owl:Class ;
    rdfs:label "City"@en ;
    rdfs:subClassOf :Location .

:Country a owl:Class ;
    rdfs:label "Country"@en ;
    rdfs:subClassOf :Location .

:Document a owl:Class ;
    rdfs:label "Document"@en .

:Invoice a owl:Class ;
    rdfs:label "Invoice"@en ;
    rdfs:subClassOf :Document .

:Contract a owl:Class ;
    rdfs:label "Contract"@en ;
    rdfs:subClassOf :Document .

:Event a owl:Class ;
    rdfs:label "Event"@en .

:Meeting a owl:Class ;
    rdfs:label "Meeting"@en ;
    rdfs:subClassOf :Event .

:Payment a owl:Class ;
    rdfs:label "Payment"@en .

:Product a owl:Class ;
    rdfs:label "Product"@en ;
    rdfs:subClassOf :Organization .

:Service a owl:Class ;
    rdfs:label "Service"@en ;
    rdfs:subClassOf :Organization .

################################################################
# Properties (15 total: object properties are declared Functional)
################################################################

# Object properties (declared as owl:ObjectProperty and owl:FunctionalProperty)
:worksAt a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "works at"@en ;
    rdfs:domain :Person ;
    rdfs:range :Organization ;
    rdfs:comment "Each Person has at most one primary organization (declared functional)."@en .

:hasAddress a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "has address"@en ;
    rdfs:domain :Organization ;
    rdfs:range :Address ;
    rdfs:comment "Each Organization has at most one primary address (declared functional)."@en .

:memberOf a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "member of"@en ;
    rdfs:domain :Person ;
    rdfs:range :Team ;
    rdfs:comment "Each Person is declared to have at most one Team membership here (functional by ontology-wide policy)."@en .

:manages a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "manages"@en ;
    rdfs:domain :Manager ;
    rdfs:range :Department ;
    rdfs:comment "A Manager has at most one managed Department (functional)."@en .

:reportsTo a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "reports to"@en ;
    rdfs:domain :Employee ;
    rdfs:range :Manager ;
    rdfs:comment "Each Employee reports to at most one Manager (functional)."@en .

:locatedIn a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "located in"@en ;
    rdfs:domain :Organization ;
    rdfs:range :City ;
    rdfs:comment "Each Organization has at most one primary City (functional)."@en .

:hasContract a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "has contract"@en ;
    rdfs:domain :Person ;
    rdfs:range :Contract ;
    rdfs:comment "Each Person has at most one primary Contract recorded (functional)."@en .

:issuesInvoice a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "issues invoice"@en ;
    rdfs:domain :Organization ;
    rdfs:range :Invoice ;
    rdfs:comment "Each Organization issues at most one primary Invoice in this simplified model (functional)."@en .

:participatesIn a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "participates in"@en ;
    rdfs:domain :Person ;
    rdfs:range :Event ;
    rdfs:comment "Each Person participates in at most one primary Event (functional for this ontology)."@en .

:organizes a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "organizes"@en ;
    rdfs:domain :Organization ;
    rdfs:range :Event ;
    rdfs:comment "Each Organization organizes at most one primary Event (functional)."@en .

# Datatype properties (not declared functional here; they are datatype properties)
:birthDate a owl:DatatypeProperty ;
    rdfs:label "birth date"@en ;
    rdfs:domain :Person ;
    rdfs:range xsd:date .

:salary a owl:DatatypeProperty ;
    rdfs:label "salary"@en ;
    rdfs:domain :Employee ;
    rdfs:range xsd:decimal .

:startDate a owl:DatatypeProperty ;
    rdfs:label "start date"@en ;
    rdfs:domain :Contract ;
    rdfs:range xsd:date .

:endDate a owl:DatatypeProperty ;
    rdfs:label "end date"@en ;
    rdfs:domain :Contract ;
    rdfs:range xsd:date .

:documentNumber a owl:DatatypeProperty ;
    rdfs:label "document number"@en ;
    rdfs:domain :Document ;
    rdfs:range xsd:string .

################################################################
# Individuals (10 total)
################################################################

:Alice a :Employee ;
    rdfs:label "Alice"@en ;
    :worksAt :AcmeInc ;
    :memberOf :PlatformTeam ;
    :reportsTo :Carol ;
    :birthDate "1987-05-12"^^xsd:date ;
    :salary "85000"^^xsd:decimal .

:Bob a :Intern ;
    rdfs:label "Bob"@en ;
    :worksAt :AcmeInc ;
    :memberOf :PlatformTeam ;
    :reportsTo :Dana ;
    :birthDate "1998-11-03"^^xsd:date ;
    :salary "30000"^^xsd:decimal .

:Carol a :Manager ;
    rdfs:label "Carol"@en ;
    :worksAt :AcmeInc ;
    :manages :EngineeringDept .

:Dana a :Manager ;
    rdfs:label "Dana"@en ;
    :worksAt :AcmeInc ;
    :manages :OperationsDept .

:AcmeInc a :Organization ;
    rdfs:label "Acme, Inc."@en ;
    :locatedIn :Metropolis ;
    :hasAddress :AcmeAddress ;
    :issuesInvoice :Invoice_001 .

:PlatformTeam a :Team ;
    rdfs:label "Platform Team"@en ;
    rdfs:subClassOf :Team .

:EngineeringDept a :Department ;
    rdfs:label "Engineering Department"@en ;
    rdfs:subClassOf :Department .

:OperationsDept a :Department ;
    rdfs:label "Operations Department"@en ;
    rdfs:subClassOf :Department .

:Metropolis a :City ;
    rdfs:label "Metropolis"@en ;
    rdfs:subClassOf :City .

:AcmeAddress a :Address ;
    rdfs:label "1 Acme Plaza"@en .

:Invoice_001 a :Invoice ;
    rdfs:label "INV-001"@en ;
    :documentNumber "INV-001" .

################################################################
# Additional subclassing to increase subclass count (high subclass count)
################################################################

:EngineeringDept rdfs:subClassOf :Organization .
:OperationsDept rdfs:subClassOf :Organization .
:PlatformTeam rdfs:subClassOf :RemoteTeam .
:RemoteTeam rdfs:subClassOf :Team .
:Manager rdfs:subClassOf :Role .
:Executive rdfs:subClassOf :Role .
:AdministrativeStaff rdfs:subClassOf :Role .
:Consultant rdfs:subClassOf :Role .
:Intern rdfs:subClassOf :Role .

################################################################
# End of ontology
################################################################