    <rdfs:label xml:lang="en">Surface Water</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#River">
    <rdfs:label xml:lang="en">River</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MonitoringSite">
    <rdfs:label xml:lang="en">Monitoring Site</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AquaticFeature">
