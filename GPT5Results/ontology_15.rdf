  <rdf:Description rdf:about="http://example.org/ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">Example Environmental Ontology</rdfs:label>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <dcterms:description xml:lang="en">An ontology describing environmental features, monitoring sites, measurements, sensors, samples, and related authorities for environmental data management.</dcterms:description>
  </rdf:Description>
