<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ex="http://example.org/ontology#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology#sedan1">
    <rdf:type rdf:resource="http://example.org/ontology#Car"/>
    <rdfs:label xml:lang="en">Sedan A-123</rdfs:label>
    <ex:locatedIn rdf:resource="http://example.org/ontology#mainBranch"/>
    <ex:relatedTo rdf:resource="http://example.org/ontology#acmeCorp"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasCapacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has capacity</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Branch"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Branch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Branch</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Location"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#producedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">produced by</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Product"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Company"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasPopulation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has population</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#City"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#acmeCorp">
    <rdf:type rdf:resource="http://example.org/ontology#Company"/>
    <rdfs:label xml:lang="en">ACME Corporation</rdfs:label>
    <ex:hasBranch rdf:resource="http://example.org/ontology#mainBranch"/>
    <ex:owns rdf:resource="http://example.org/ontology#product1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#alice">
    <rdf:type rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:label xml:lang="en">Alice</rdfs:label>
    <ex:worksFor rdf:resource="http://example.org/ontology#acmeCorp"/>
    <ex:hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">34</ex:hasAge>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Organization</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#doc1">
    <rdf:type rdf:resource="http://example.org/ontology#Document"/>
    <rdfs:label xml:lang="en">Project X Requirements</rdfs:label>
    <ex:hasFileSize rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.45</ex:hasFileSize>
    <ex:relatedTo rdf:resource="http://example.org/ontology#projectX"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Artifact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Artifact</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Project">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Project</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Car">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Car</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Vehicle"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Place">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Place</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#projectX">
    <rdf:type rdf:resource="http://example.org/ontology#Project"/>
    <rdfs:label xml:lang="en">Project X</rdfs:label>
    <ex:assignedTo rdf:resource="http://example.org/ontology#alice"/>
    <ex:hasStartDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-01-15</ex:hasStartDate>
    <ex:hasEndDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-12-31</ex:hasEndDate>
    <ex:locatedIn rdf:resource="http://example.org/ontology#mainBranch"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Employee">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Employee</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Person"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#City">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">City</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Location"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasStartDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has start date</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Project"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Product">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Product</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Artifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#locatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">located in</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Entity"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Place"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#relatedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">related to</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Entity"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasAge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has age</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#bob">
    <rdf:type rdf:resource="http://example.org/ontology#Manager"/>
    <rdfs:label xml:lang="en">Bob</rdfs:label>
    <ex:worksFor rdf:resource="http://example.org/ontology#acmeCorp"/>
    <ex:manages rdf:resource="http://example.org/ontology#projectX"/>
    <ex:hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">41</ex:hasAge>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Animal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Animal</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasPrice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has price</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasEndDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has end date</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Project"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#mainBranch">
    <rdf:type rdf:resource="http://example.org/ontology#Branch"/>
    <rdfs:label xml:lang="en">ACME Main Branch</rdfs:label>
    <ex:locatedIn rdf:resource="http://example.org/ontology#paris"/>
    <ex:hasCapacity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">250</ex:hasCapacity>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#worksFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">works for</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Organization"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#product1">
    <rdf:type rdf:resource="http://example.org/ontology#Product"/>
    <rdfs:label xml:lang="en">Widget-1000</rdfs:label>
    <ex:hasPrice rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">19.99</ex:hasPrice>
    <ex:producedBy rdf:resource="http://example.org/ontology#acmeCorp"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Manager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Manager</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Employee"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#File">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">File</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Document"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Company">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Company</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Organization"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#fido">
    <rdf:type rdf:resource="http://example.org/ontology#Dog"/>
    <rdfs:label xml:lang="en">Fido</rdfs:label>
    <ex:hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:hasAge>
    <ex:relatedTo rdf:resource="http://example.org/ontology#alice"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasBranch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has branch</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Company"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Branch"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#manages">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">manages</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Manager"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Project"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#assignedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">assigned to</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Project"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Employee"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Entity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Entity</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasFileSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has file size</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#File"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#paris">
    <rdf:type rdf:resource="http://example.org/ontology#City"/>
    <rdfs:label xml:lang="en">Paris</rdfs:label>
    <ex:hasPopulation rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2161000</ex:hasPopulation>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Agent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Agent</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Dog">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Dog</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Animal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Document">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Document</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Artifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Vehicle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Vehicle</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#owns">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">owns</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Organization"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Artifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">Example Ontology with Data Properties and Labels</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Location">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Location</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Place"/>
  </rdf:Description>
</rdf:RDF>
