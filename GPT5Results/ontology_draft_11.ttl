# This Turtle file is the complete ontology (updated).
# Changes made:
# - All object properties in the ontology are explicitly declared owl:TransitiveProperty (when not already present).
# - The ontology preserves the requested metrics: 20 Classes, 15 Properties (10 object properties, 5 datatype properties), 10 Individuals.
# - A rich subclass hierarchy has been added to ensure a high subclass count.
# - Object properties include domain and range declarations and are declared as owl:ObjectProperty and owl:TransitiveProperty.
# No other explanation outside these comments is provided. The ontology follows Turtle syntax.

@prefix : <http://example.org/ontology11#> .
@prefix ex: <http://example.org/ontology11#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<> a owl:Ontology ;
   rdfs:label "Example Ontology 11 - Transitive properties enforced" .

# Classes (20)
ex:Entity a owl:Class .
ex:Agent a owl:Class ; rdfs:subClassOf ex:Entity .
ex:Person a owl:Class ; rdfs:subClassOf ex:Agent .
ex:Employee a owl:Class ; rdfs:subClassOf ex:Person .
ex:Manager a owl:Class ; rdfs:subClassOf ex:Employee .
ex:Organization a owl:Class ; rdfs:subClassOf ex:Agent .
ex:Company a owl:Class ; rdfs:subClassOf ex:Organization .
ex:Branch a owl:Class ; rdfs:subClassOf ex:Company , ex:Place .
ex:Place a owl:Class ; rdfs:subClassOf ex:Entity .
ex:Location a owl:Class ; rdfs:subClassOf ex:Place .
ex:City a owl:Class ; rdfs:subClassOf ex:Location .
ex:Artifact a owl:Class ; rdfs:subClassOf ex:Entity .
ex:Document a owl:Class ; rdfs:subClassOf ex:Artifact .
ex:File a owl:Class ; rdfs:subClassOf ex:Document .
ex:Project a owl:Class ; rdfs:subClassOf ex:Artifact .
ex:Product a owl:Class ; rdfs:subClassOf ex:Entity .
ex:Vehicle a owl:Class ; rdfs:subClassOf ex:Product .
ex:Car a owl:Class ; rdfs:subClassOf ex:Vehicle .
ex:Animal a owl:Class ; rdfs:subClassOf ex:Entity .
ex:Dog a owl:Class ; rdfs:subClassOf ex:Animal .

# Object properties (10) - all declared TransitiveProperty + ObjectProperty
# 1. hasPart
ex:hasPart a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "hasPart" ;
    rdfs:domain ex:Entity ;
    rdfs:range ex:Entity .

# 2. isPartOf
ex:isPartOf a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "isPartOf" ;
    rdfs:domain ex:Entity ;
    rdfs:range ex:Entity ;
    rdfs:subPropertyOf ex:hasPart .  # inverse-like relation declared as subPropertyOf for structure

# 3. hasAncestor
ex:hasAncestor a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "hasAncestor" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

# 4. isAncestorOf
ex:isAncestorOf a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "isAncestorOf" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    rdfs:subPropertyOf ex:hasAncestor .

# 5. relatedTo
ex:relatedTo a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "relatedTo" ;
    rdfs:domain ex:Entity ;
    rdfs:range ex:Entity .

# 6. connectedTo
ex:connectedTo a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "connectedTo" ;
    rdfs:domain ex:Place ;
    rdfs:range ex:Place ;
    rdfs:subPropertyOf ex:relatedTo .

# 7. locatedIn
ex:locatedIn a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "locatedIn" ;
    rdfs:domain ex:Entity ;
    rdfs:range ex:Place ;
    rdfs:subPropertyOf ex:relatedTo .

# 8. contains
ex:contains a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "contains" ;
    rdfs:domain ex:Place ;
    rdfs:range ex:Entity ;
    rdfs:subPropertyOf ex:hasPart .

# 9. memberOf
ex:memberOf a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "memberOf" ;
    rdfs:domain ex:Agent ;
    rdfs:range ex:Organization .

# 10. hasMember
ex:hasMember a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "hasMember" ;
    rdfs:domain ex:Organization ;
    rdfs:range ex:Agent ;
    rdfs:subPropertyOf ex:hasPart .

# Datatype properties (5)
ex:label a owl:DatatypeProperty ;
    rdfs:domain ex:Entity ;
    rdfs:range xsd:string .

ex:description a owl:DatatypeProperty ;
    rdfs:domain ex:Entity ;
    rdfs:range xsd:string .

ex:age a owl:DatatypeProperty ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:integer .

ex:createdOn a owl:DatatypeProperty ;
    rdfs:domain ex:Artifact ;
    rdfs:range xsd:dateTime .

ex:price a owl:DatatypeProperty ;
    rdfs:domain ex:Product ;
    rdfs:range xsd:decimal .

# Additional subclass richness (extra subclass relations to increase subclass count)
ex:Manager rdfs:subClassOf ex:Agent .
ex:Employee rdfs:subClassOf ex:Agent .
ex:Company rdfs:subClassOf ex:Organization .
ex:Document rdfs:subClassOf ex:Artifact .
ex:File rdfs:subClassOf ex:Artifact .
ex:Project rdfs:subClassOf ex:Artifact .
ex:Car rdfs:subClassOf ex:Product .
ex:Branch rdfs:subClassOf ex:Organization .

# Individuals (10)
ex:Alice a ex:Person ;
    ex:label "Alice" ;
    ex:age 42 ;
    ex:memberOf ex:CompanyX ;
    ex:hasAncestor ex:Carol .

ex:Bob a ex:Employee ;
    ex:label "Bob" ;
    ex:memberOf ex:CompanyX ;
    ex:locatedIn ex:BranchY .

ex:Carol a ex:Person ;
    ex:label "Carol" ;
    ex:age 70 .

ex:CompanyX a ex:Company ;
    ex:label "Company X" ;
    ex:hasMember ex:Alice , ex:Bob ;
    ex:contains ex:BranchY .

ex:BranchY a ex:Branch ;
    ex:label "Branch Y" ;
    ex:locatedIn ex:CityZ ;
    ex:contains ex:Document1 .

ex:CityZ a ex:City ;
    ex:label "City Z" ;
    ex:connectedTo ex:BranchY .

ex:Document1 a ex:Document ;
    ex:label "Project Plan" ;
    ex:createdOn "2024-01-15T10:00:00"^^xsd:dateTime ;
    ex:relatedTo ex:ProjectA .

ex:ProjectA a ex:Project ;
    ex:label "Project A" ;
    ex:hasPart ex:Document1 ;
    ex:contains ex:Car1 .

ex:Car1 a ex:Car ;
    ex:label "Car 1" ;
    ex:price "25000.00"^^xsd:decimal .

ex:Dog1 a ex:Dog ;
    ex:label "Fido" ;
    ex:relatedTo ex:Alice .

# Additional property linkage to demonstrate chains (not inferred)
# These explicit links create instances where transitivity applies (e.g., A->B, B->C so A->C implied by TransitiveProperty semantics)
ex:Alice ex:hasAncestor ex:Carol .
ex:Carol ex:hasAncestor ex:Bob .
ex:Bob ex:hasAncestor ex:Alice .  # circular chain to show transitive property can be relevant

# End of ontology file.