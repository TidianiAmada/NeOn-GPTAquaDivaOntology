<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ex="http://example.org/ontology11#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology11#hasMember">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>hasMember</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Organization"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Agent"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/ontology11#hasPart"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Branch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Company"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Place"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Organization"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Car">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Vehicle"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Product"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#ProjectA">
    <rdf:type rdf:resource="http://example.org/ontology11#Project"/>
    <ex:label>Project A</ex:label>
    <ex:hasPart rdf:resource="http://example.org/ontology11#Document1"/>
    <ex:contains rdf:resource="http://example.org/ontology11#Car1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#label">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#memberOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>memberOf</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Agent"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Organization"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Animal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#locatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>locatedIn</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Place"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/ontology11#relatedTo"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#CityZ">
    <rdf:type rdf:resource="http://example.org/ontology11#City"/>
    <ex:label>City Z</ex:label>
    <ex:connectedTo rdf:resource="http://example.org/ontology11#BranchY"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Document1">
    <rdf:type rdf:resource="http://example.org/ontology11#Document"/>
    <ex:label>Project Plan</ex:label>
    <ex:createdOn rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-01-15T10:00:00</ex:createdOn>
    <ex:relatedTo rdf:resource="http://example.org/ontology11#ProjectA"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Bob">
    <rdf:type rdf:resource="http://example.org/ontology11#Employee"/>
    <ex:label>Bob</ex:label>
    <ex:memberOf rdf:resource="http://example.org/ontology11#CompanyX"/>
    <ex:locatedIn rdf:resource="http://example.org/ontology11#BranchY"/>
    <ex:hasAncestor rdf:resource="http://example.org/ontology11#Alice"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Manager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Employee"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="file:///app/GPT5Results/ontology_draft_11.ttl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label>Example Ontology 11 - Transitive properties enforced</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#contains">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>contains</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Place"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/ontology11#hasPart"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Project">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Artifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Dog">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Animal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#BranchY">
    <rdf:type rdf:resource="http://example.org/ontology11#Branch"/>
    <ex:label>Branch Y</ex:label>
    <ex:locatedIn rdf:resource="http://example.org/ontology11#CityZ"/>
    <ex:contains rdf:resource="http://example.org/ontology11#Document1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#City">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Location"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Car1">
    <rdf:type rdf:resource="http://example.org/ontology11#Car"/>
    <ex:label>Car 1</ex:label>
    <ex:price rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">25000.00</ex:price>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#price">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Employee">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Person"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Agent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Carol">
    <rdf:type rdf:resource="http://example.org/ontology11#Person"/>
    <ex:label>Carol</ex:label>
    <ex:age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">70</ex:age>
    <ex:hasAncestor rdf:resource="http://example.org/ontology11#Bob"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Artifact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#hasAncestor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>hasAncestor</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Person"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Person"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Agent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Dog1">
    <rdf:type rdf:resource="http://example.org/ontology11#Dog"/>
    <ex:label>Fido</ex:label>
    <ex:relatedTo rdf:resource="http://example.org/ontology11#Alice"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#connectedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>connectedTo</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Place"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Place"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/ontology11#relatedTo"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Product">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#createdOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Artifact"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#isPartOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>isPartOf</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/ontology11#hasPart"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Location">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Place"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#File">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Document"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Artifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Document">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Artifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#relatedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>relatedTo</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Company">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Organization"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Alice">
    <rdf:type rdf:resource="http://example.org/ontology11#Person"/>
    <ex:label>Alice</ex:label>
    <ex:age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">42</ex:age>
    <ex:memberOf rdf:resource="http://example.org/ontology11#CompanyX"/>
    <ex:hasAncestor rdf:resource="http://example.org/ontology11#Carol"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#CompanyX">
    <rdf:type rdf:resource="http://example.org/ontology11#Company"/>
    <ex:label>Company X</ex:label>
    <ex:hasMember rdf:resource="http://example.org/ontology11#Alice"/>
    <ex:hasMember rdf:resource="http://example.org/ontology11#Bob"/>
    <ex:contains rdf:resource="http://example.org/ontology11#BranchY"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Vehicle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Product"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#hasPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>hasPart</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Entity"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Place">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology11#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#Entity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#isAncestorOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label>isAncestorOf</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Person"/>
    <rdfs:range rdf:resource="http://example.org/ontology11#Person"/>
    <rdfs:subPropertyOf rdf:resource="http://example.org/ontology11#hasAncestor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology11#age">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/ontology11#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
</rdf:RDF>
