  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Dana">
    <rdf:type rdf:resource="http://example.org/ontology#Manager"/>
    <rdfs:label xml:lang="en">Dana</rdfs:label>
    <worksAt rdf:resource="http://example.org/ontology#AcmeInc"/>
    <manages rdf:resource="http://example.org/ontology#OperationsDept"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#reportsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">reports to</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Employee"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Manager"/>
    <rdfs:comment xml:lang="en">Each Employee reports to at most one Manager (functional).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Meeting">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Meeting</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Employee">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Employee</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Person"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has address</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Organization"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Address"/>
    <rdfs:comment xml:lang="en">Each Organization has at most one primary address (declared functional).</rdfs:comment>
  </rdf:Description>
