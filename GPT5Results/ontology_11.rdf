  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasContract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has contract</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Person"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Contract"/>
    <rdfs:comment xml:lang="en">Each Person has at most one primary Contract recorded (functional).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="file:///app/GPT5Results/ontology_draft_10.ttl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">Example Organization Ontology (augmented)</rdfs:label>
    <rdfs:comment xml:lang="en">Functional declarations added for all object properties; labels added for all classes to satisfy SHACL minCount constraints.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Document">
