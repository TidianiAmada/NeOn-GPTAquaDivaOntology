    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Administrative Staff</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#Employee"/>
