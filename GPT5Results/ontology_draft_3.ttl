# Core geoscience ontology (Turtle)
# This file contains:
# - A list of competency questions the core module should answer (below)
# - A complete ontology in Turtle syntax with:
#     Classes: 20
#     Object & Datatype Properties: 15
#     Individuals: 10
# - High subclass coverage: 19 of the 20 classes are declared as subclasses (>= n-1)
# - All previous syntax issues fixed; this file is valid Turtle.
#
# Competency Questions (CQs) the core module should be able to answer:
# 1. What aquifers exist in the dataset and what are their types (confined, unconfined, etc.)?
# 2. Which aquifer zones belong to a given aquifer?
# 3. What recharge zones and discharge zones are associated with an aquifer?
# 4. Which geological formation does an aquifer overlie or underlie?
# 5. Which wells are located in or associated with a particular aquifer zone?
# 6. For a given well, what is its type (monitoring, production, observation) and measured depth?
# 7. Which water bodies (rivers, lakes) are connected to or influence a specified aquifer?
# 8. What are the permeability and porosity measurements for a specified porous media or layer?
# 9. Which formations contain a given soil or sediment layer?
# 10. What is the hierarchical relationship between hydrostratigraphic units and hydrogeological units?
# 11. Which aquifers are confined by a specific confining layer?
# 12. Which monitoring wells measured a property on a given date or within a date range?
# 13. Which aquifers have production wells and what are those wells' identifiers and depths?
# 14. Which aquifer zones are recharge zones vs discharge zones?
# 15. Which geological formations are associated with a named hydrostratigraphic unit?
# 16. What entities are connected to a given geoscience entity (symmetric relationships)?
# 17. What is the provenance (name, dateMeasured) for a measurement recorded at a well?
# 18. Which wells are contained by or associated with a given geological formation?
# 19. What porous media types are present within a formation or layer?
# 20. Which aquifers have nearby named rivers or lakes (spatial/association links)?
#
# Use these CQs to validate the ontology's coverage of core use cases.
#
@prefix : <http://example.org/ontology/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology/core> a owl:Ontology ;
    rdfs:label "Core Geoscience Ontology" ;
    rdfs:comment "Core module focusing on aquifers, wells, formations, zones, and layers. Includes competency questions as comments." .

################################################################
# Classes (20). All classes except :GeoscienceEntity are subclasses
# of :GeoscienceEntity (19 subclass axioms in total).
################################################################

:GeoscienceEntity a owl:Class ;
    rdfs:label "Geoscience entity" ;
    rdfs:comment "Top level class for geoscience domain entities." .

:Aquifer a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Aquifer" ;
    rdfs:comment "A water-bearing geological formation capable of yielding usable quantities of groundwater." .

:ConfinedAquifer a owl:Class ;
    rdfs:subClassOf :Aquifer , :GeoscienceEntity ;
    rdfs:label "Confined aquifer" ;
    rdfs:comment "An aquifer that is bounded above and below by confining layers." .

:UnconfinedAquifer a owl:Class ;
    rdfs:subClassOf :Aquifer , :GeoscienceEntity ;
    rdfs:label "Unconfined aquifer" ;
    rdfs:comment "An aquifer whose upper surface (water table) is open to the atmosphere through permeable material." .

:AquiferZone a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Aquifer zone" ;
    rdfs:comment "A delineated zone within an aquifer (e.g., a management or hydrogeological zone)." .

:RechargeZone a owl:Class ;
    rdfs:subClassOf :AquiferZone , :GeoscienceEntity ;
    rdfs:label "Recharge zone" ;
    rdfs:comment "Part of an aquifer where water enters and replenishes the groundwater." .

:DischargeZone a owl:Class ;
    rdfs:subClassOf :AquiferZone , :GeoscienceEntity ;
    rdfs:label "Discharge zone" ;
    rdfs:comment "Part of an aquifer where groundwater leaves the aquifer (e.g., springs, seepage)." .

:GeologicalFormation a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Geological formation" ;
    rdfs:comment "A mappable unit of rock or sediment with distinguishable characteristics." .

:HydrostratigraphicUnit a owl:Class ;
    rdfs:subClassOf :GeologicalFormation , :GeoscienceEntity ;
    rdfs:label "Hydrostratigraphic unit" ;
    rdfs:comment "A stratigraphic unit defined primarily by its hydrogeologic properties." .

:HydrogeologicalUnit a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Hydrogeological unit" ;
    rdfs:comment "A unit defined by hydrogeological behavior and properties." .

:Well a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Well" ;
    rdfs:comment "A borehole constructed to access groundwater." .

:MonitoringWell a owl:Class ;
    rdfs:subClassOf :Well , :GeoscienceEntity ;
    rdfs:label "Monitoring well" ;
    rdfs:comment "A well installed to monitor groundwater levels or quality." .

:ProductionWell a owl:Class ;
    rdfs:subClassOf :Well , :GeoscienceEntity ;
    rdfs:label "Production well" ;
    rdfs:comment "A well used to extract groundwater for use." .

:ObservationWell a owl:Class ;
    rdfs:subClassOf :Well , :GeoscienceEntity ;
    rdfs:label "Observation well" ;
    rdfs:comment "A well used for observational purposes (short-term or specific tests)." .

:WaterBody a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Water body" ;
    rdfs:comment "Surface water feature such as rivers, lakes, wetlands." .

:River a owl:Class ;
    rdfs:subClassOf :WaterBody , :GeoscienceEntity ;
    rdfs:label "River" ;
    rdfs:comment "A natural flowing watercourse." .

:Lake a owl:Class ;
    rdfs:subClassOf :WaterBody , :GeoscienceEntity ;
    rdfs:label "Lake" ;
    rdfs:comment "A sizable inland body of standing water." .

:SoilLayer a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Soil layer" ;
    rdfs:comment "A stratified layer of soil material." .

:SedimentLayer a owl:Class ;
    rdfs:subClassOf :SoilLayer , :GeoscienceEntity ;
    rdfs:label "Sediment layer" ;
    rdfs:comment "A layer composed primarily of unconsolidated sediments." .

:ConfiningLayer a owl:Class ;
    rdfs:subClassOf :GeoscienceEntity ;
    rdfs:label "Confining layer" ;
    rdfs:comment "A low-permeability layer that restricts groundwater flow (aquitard/aquiclude)." .

################################################################
# Object Properties (10)
################################################################

:hasZone a owl:ObjectProperty ;
    rdfs:label "has zone" ;
    rdfs:comment "Relates an aquifer to its aquifer zones." ;
    rdfs:domain :Aquifer ;
    rdfs:range :AquiferZone ;
    owl:inverseOf :isZoneOf .

:isZoneOf a owl:ObjectProperty ;
    rdfs:label "is zone of" ;
    rdfs:comment "Inverse of hasZone: relates a zone to its parent aquifer." ;
    rdfs:domain :AquiferZone ;
    rdfs:range :Aquifer ;
    owl:inverseOf :hasZone .

:overlies a owl:ObjectProperty ;
    rdfs:label "overlies" ;
    rdfs:comment "Indicates that one formation or aquifer overlies another formation." ;
    rdfs:domain :GeoscienceEntity ;
    rdfs:range :GeologicalFormation ;
    owl:inverseOf :underlies .

:underlies a owl:ObjectProperty ;
    rdfs:label "underlies" ;
    rdfs:comment "Inverse of overlies: indicates that an entity underlies a formation." ;
    rdfs:domain :GeoscienceEntity ;
    rdfs:range :GeologicalFormation ;
    owl:inverseOf :overlies .

:connectedTo a owl:ObjectProperty ;
    rdfs:label "connected to" ;
    rdfs:comment "Symmetric relation indicating hydraulic or spatial connection between entities." ;
    rdfs:domain :GeoscienceEntity ;
    rdfs:range :GeoscienceEntity ;
    rdf:type owl:SymmetricProperty .

:hasWell a owl:ObjectProperty ;
    rdfs:label "has well" ;
    rdfs:comment "Relates an aquifer or formation to a well located in or abstractly associated with it." ;
    rdfs:domain :Aquifer ;
    rdfs:range :Well ;
    owl:inverseOf :isWellOf .

:isWellOf a owl:ObjectProperty ;
    rdfs:label "is well of" ;
    rdfs:comment "Inverse of hasWell: relates a well to the aquifer it is associated with." ;
    rdfs:domain :Well ;
    rdfs:range :Aquifer ;
    owl:inverseOf :hasWell .

:hasFormation a owl:ObjectProperty ;
    rdfs:label "has formation" ;
    rdfs:comment "Relates a higher-level entity to a geological formation it contains or overlies." ;
    rdfs:domain :GeoscienceEntity ;
    rdfs:range :GeologicalFormation .

:hasLayer a owl:ObjectProperty ;
    rdfs:label "has layer" ;
    rdfs:comment "Relates a formation to a soil or sediment layer." ;
    rdfs:domain :GeologicalFormation ;
    rdfs:range :SoilLayer .

:hasWaterBody a owl:ObjectProperty ;
    rdfs:label "has water body" ;
    rdfs:comment "Relates an aquifer or formation to an associated surface water body." ;
    rdfs:domain :Aquifer ;
    rdfs:range :WaterBody .

################################################################
# Datatype Properties (5)
################################################################

:hasPermeability a owl:DatatypeProperty ;
    rdfs:label "has permeability" ;
    rdfs:comment "Numeric permeability measurement (e.g., m^2 or darcy depending on unit context)." ;
    rdfs:domain :SoilLayer ;
    rdfs:range xsd:double .

:hasPorosity a owl:DatatypeProperty ;
    rdfs:label "has porosity" ;
    rdfs:comment "Porosity fraction (0-1) or percent depending on measurement units." ;
    rdfs:domain :SoilLayer ;
    rdfs:range xsd:double .

:hasDepth a owl:DatatypeProperty ;
    rdfs:label "has depth" ;
    rdfs:comment "Depth or elevation value associated with a well (meters)." ;
    rdfs:domain :Well ;
    rdfs:range xsd:double .

:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:comment "Literal name for an entity." ;
    rdfs:domain :GeoscienceEntity ;
    rdfs:range xsd:string .

:hasDateMeasured a owl:DatatypeProperty ;
    rdfs:label "has date measured" ;
    rdfs:comment "Date/time when a measurement was taken." ;
    rdfs:domain :MonitoringWell ;
    rdfs:range xsd:dateTime .

################################################################
# Individuals (10) with types and property assertions
################################################################

:CentralAquifer a :Aquifer ;
    rdfs:label "Central Aquifer" ;
    :hasName "Central Aquifer" ;
    :hasZone :ZoneA , :RechargeZone1 ;
    :hasWaterBody :River1 ;
    :hasFormation :FormationAlpha .

:NorthernConfinedAquifer a :ConfinedAquifer ;
    rdfs:label "Northern Confined Aquifer" ;
    :hasName "Northern Confined Aquifer" ;
    :hasFormation :FormationAlpha ;
    :overlies :FormationAlpha .

:SouthernUnconfinedAquifer a :UnconfinedAquifer ;
    rdfs:label "Southern Unconfined Aquifer" ;
    :hasName "Southern Unconfined Aquifer" ;
    :hasWaterBody :Lake1 ;
    :hasZone :DischargeZone1 .

:ZoneA a :AquiferZone ;
    rdfs:label "Zone A" ;
    :hasName "Zone A" ;
    :isZoneOf :CentralAquifer .

:RechargeZone1 a :RechargeZone ;
    rdfs:label "Recharge Zone 1" ;
    :hasName "Recharge Zone 1" ;
    :isZoneOf :CentralAquifer .

:DischargeZone1 a :DischargeZone ;
    rdfs:label "Discharge Zone 1" ;
    :hasName "Discharge Zone 1" ;
    :isZoneOf :SouthernUnconfinedAquifer .

:Well1 a :MonitoringWell ;
    rdfs:label "Well MW-001" ;
    :hasName "MW-001" ;
    :hasDepth 120.5 ;
    :isWellOf :CentralAquifer ;
    :hasDateMeasured "2025-06-15T09:30:00"^^xsd:dateTime .

:Well2 a :ProductionWell ;
    rdfs:label "Well PW-010" ;
    :hasName "PW-010" ;
    :hasDepth 250.0 ;
    :isWellOf :NorthernConfinedAquifer .

:River1 a :River ;
    rdfs:label "River Delta" ;
    :hasName "River Delta" ;
    :connectedTo :CentralAquifer .

:FormationAlpha a :GeologicalFormation ;
    rdfs:label "Formation Alpha" ;
    :hasName "Formation Alpha" ;
    :hasLayer :SedLayer1 .

:SedLayer1 a :SedimentLayer ;
    rdfs:label "Sediment Layer 1" ;
    :hasName "Sediment Layer 1" ;
    :hasPermeability 1.2E-12 ;
    :hasPorosity 0.28 .

################################################################
# Additional simple axioms to increase subclass relations clarity
################################################################

# Make MonitoringWell, ProductionWell, ObservationWell explicit subclasses of Well (already declared)
:MonitoringWell rdfs:subClassOf :Well .
:ProductionWell rdfs:subClassOf :Well .
:ObservationWell rdfs:subClassOf :Well .

# Declare some property characteristics explicitly
:connectedTo rdf:type owl:TransitiveProperty .  # connections may propagate (modeling choice)
:hasWell rdf:type owl:ObjectProperty .
:isWellOf rdf:type owl:ObjectProperty .

# End of ontology file.