:createdBy owl:inverseOf :creates .

:hasOwner owl:inverseOf :isOwnerOf .

:hasParent owl:inverseOf :isChildOf .

:hasPart owl:inverseOf :isPartOf .

:locatedIn owl:inverseOf :locationOf .

:manages owl:inverseOf :managedBy .

:worksFor owl:inverseOf :employs .

