  <rdf:Description rdf:about="http://example.org/ontology#Watershed">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#EnvironmentalFeature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
