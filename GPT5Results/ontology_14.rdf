<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ex="http://example.org/ontology#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/ontology#Authority_Fed">
    <rdf:type rdf:resource="http://example.org/ontology#Authority"/>
    <ex:hasName>National Environmental Authority</ex:hasName>
    <ex:hasID>AUTH-FED-01</ex:hasID>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#installationDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>installationDate</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Sensor"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Wetland">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SurfaceWater"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Aquifer1">
    <rdf:type rdf:resource="http://example.org/ontology#Aquifer"/>
    <ex:hasName>Edenspring Aquifer</ex:hasName>
    <ex:hasID>AQ-001</ex:hasID>
    <ex:depth rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">120.5</ex:depth>
    <ex:locatedIn rdf:resource="http://example.org/ontology#Watershed_W1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasSample">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasSample</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#MonitoringSite"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Sample"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Well_Alpha">
    <rdf:type rdf:resource="http://example.org/ontology#Well"/>
    <ex:hasName>Alpha Well</ex:hasName>
    <ex:hasID>WL-ALPHA</ex:hasID>
    <ex:depth rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">85.0</ex:depth>
    <ex:locatedIn rdf:resource="http://example.org/ontology#Aquifer1"/>
    <ex:operatedBy rdf:resource="http://example.org/ontology#Authority_ENV"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>hasName</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Feature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#RiverGlen">
    <rdf:type rdf:resource="http://example.org/ontology#River"/>
    <ex:hasName>Glen River</ex:hasName>
    <ex:hasID>RV-210</ex:hasID>
    <ex:flowRate rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">45.3</ex:flowRate>
    <ex:locatedIn rdf:resource="http://example.org/ontology#Watershed_W1"/>
    <ex:flowsInto rdf:resource="http://example.org/ontology#LakeSilver"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Contam_Lead">
    <rdf:type rdf:resource="http://example.org/ontology#Contaminant"/>
    <ex:hasName>Lead</ex:hasName>
    <ex:hasID>C-002</ex:hasID>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#WetlandOld">
    <rdf:type rdf:resource="http://example.org/ontology#Wetland"/>
    <ex:hasName>Old Marsh</ex:hasName>
    <ex:hasID>WL-410</ex:hasID>
    <ex:locatedIn rdf:resource="http://example.org/ontology#Watershed_W1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Measurement_M1">
    <rdf:type rdf:resource="http://example.org/ontology#Measurement"/>
    <ex:hasName>Nitrate concentration</ex:hasName>
    <ex:hasID>M-9001</ex:hasID>
    <ex:concentration rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.8</ex:concentration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Measurement_M2">
    <rdf:type rdf:resource="http://example.org/ontology#Measurement"/>
    <ex:hasName>Lead concentration</ex:hasName>
    <ex:hasID>M-9002</ex:hasID>
    <ex:concentration rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.015</ex:concentration>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Sample_002">
    <rdf:type rdf:resource="http://example.org/ontology#Sample"/>
    <ex:hasID>SMP-1002</ex:hasID>
    <ex:measuredAt rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-16T09:15:00</ex:measuredAt>
    <ex:hasMeasurement rdf:resource="http://example.org/ontology#Measurement_M2"/>
    <ex:containsContaminant rdf:resource="http://example.org/ontology#Contam_Lead"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#measuredAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>measuredAt</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Sample"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#containsContaminant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>containsContaminant</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Sample"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Contaminant"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#concentration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>concentration</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Measurement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#flowsInto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>flowsInto</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#SurfaceWater"/>
    <rdfs:range rdf:resource="http://example.org/ontology#SurfaceWater"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Authority_ENV">
    <rdf:type rdf:resource="http://example.org/ontology#Authority"/>
    <ex:hasName>Regional Environmental Agency</ex:hasName>
    <ex:hasID>AUTH-ENV-01</ex:hasID>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#depth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>depth</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Feature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasMeasurement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasMeasurement</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Sample"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Measurement"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Well_Beta">
    <rdf:type rdf:resource="http://example.org/ontology#Well"/>
    <ex:hasName>Beta Well</ex:hasName>
    <ex:hasID>WL-BETA</ex:hasID>
    <ex:depth rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">60.0</ex:depth>
    <ex:locatedIn rdf:resource="http://example.org/ontology#Aquifer1"/>
    <ex:operatedBy rdf:resource="http://example.org/ontology#Authority_ENV"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#monitoredBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>monitoredBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#MonitoringSite"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Sensor_S1">
    <rdf:type rdf:resource="http://example.org/ontology#Sensor"/>
    <ex:hasName>T-Logger-100</ex:hasName>
    <ex:hasID>SN-100</ex:hasID>
    <ex:installationDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-10</ex:installationDate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Watershed_W1">
    <rdf:type rdf:resource="http://example.org/ontology#Watershed"/>
    <ex:hasName>Green River Catchment</ex:hasName>
    <ex:hasID>WS-101</ex:hasID>
    <ex:hasPart rdf:resource="http://example.org/ontology#RiverGlen"/>
    <ex:hasPart rdf:resource="http://example.org/ontology#LakeSilver"/>
    <ex:hasPart rdf:resource="http://example.org/ontology#WetlandOld"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Sample_001">
    <rdf:type rdf:resource="http://example.org/ontology#Sample"/>
    <ex:hasID>SMP-1001</ex:hasID>
    <ex:measuredAt rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-15T10:30:00</ex:measuredAt>
    <ex:hasMeasurement rdf:resource="http://example.org/ontology#Measurement_M1"/>
    <ex:containsContaminant rdf:resource="http://example.org/ontology#Contam_Nitrate"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#operatedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>operatedBy</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Feature"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Authority"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#flowRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
