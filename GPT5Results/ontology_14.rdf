  <rdf:Description rdf:about="http://example.org/ontology#Well">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#ManagedFeature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:comment>Environmental monitoring ontology (populated with individuals).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#hasID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
