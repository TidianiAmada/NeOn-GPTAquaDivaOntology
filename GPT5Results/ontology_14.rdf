    <ex:hasName>Highcrest Dam</ex:hasName>
    <ex:hasID>DM-77</ex:hasID>
    <ex:installationDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1989-06-15</ex:installationDate>
    <ex:locatedIn rdf:resource="http://example.org/ontology#RiverGlen"/>
    <ex:operatedBy rdf:resource="http://example.org/ontology#Authority_ENV"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Sensor">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#ManagedFeature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MonitoringSite">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#ManagedFeature"/>
