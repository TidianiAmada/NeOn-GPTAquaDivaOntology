    <rdfs:domain rdf:resource="http://example.org/ontology#SurfaceWater"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MonitoringSite_MS2">
    <rdf:type rdf:resource="http://example.org/ontology#MonitoringSite"/>
    <ex:hasName>MS - Lake Silver</ex:hasName>
    <ex:hasID>MS-002</ex:hasID>
    <ex:locatedIn rdf:resource="http://example.org/ontology#LakeSilver"/>
    <ex:hasSample rdf:resource="http://example.org/ontology#Sample_002"/>
    <ex:monitoredBy rdf:resource="http://example.org/ontology#Sensor_S2"/>
    <ex:operatedBy rdf:resource="http://example.org/ontology#Authority_ENV"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Contam_Nitrate">
    <rdf:type rdf:resource="http://example.org/ontology#Contaminant"/>
    <ex:hasName>Nitrate</ex:hasName>
    <ex:hasID>C-001</ex:hasID>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#MonitoringSite_MS1">
    <rdf:type rdf:resource="http://example.org/ontology#MonitoringSite"/>
    <ex:hasName>MS - Glen Rd</ex:hasName>
    <ex:hasID>MS-001</ex:hasID>
    <ex:locatedIn rdf:resource="http://example.org/ontology#RiverGlen"/>
    <ex:hasSample rdf:resource="http://example.org/ontology#Sample_001"/>
    <ex:monitoredBy rdf:resource="http://example.org/ontology#Sensor_S1"/>
    <ex:operatedBy rdf:resource="http://example.org/ontology#Authority_ENV"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Dam">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#ManagedFeature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#locatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>locatedIn</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/ontology#Feature"/>
    <rdfs:range rdf:resource="http://example.org/ontology#Feature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#ManagedFeature">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#EnvironmentalFeature"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#LakeSilver">
    <rdf:type rdf:resource="http://example.org/ontology#Lake"/>
    <ex:hasName>Lake Silver</ex:hasName>
    <ex:hasID>LK-305</ex:hasID>
    <ex:depth rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">30.0</ex:depth>
    <ex:locatedIn rdf:resource="http://example.org/ontology#Watershed_W1"/>
    <ex:hasPart rdf:resource="http://example.org/ontology#WetlandOld"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#Lake">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/ontology#SurfaceWater"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/ontology#AquaticFeature">
