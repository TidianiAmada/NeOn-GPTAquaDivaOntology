# Refined ENVO-inspired ontology in Turtle syntax.
# This file defines a hierarchical structure for environmental concepts,
# with focus on hydrogeological features (e.g., Aquifer) and properties such as hasDepth.
# All explanatory text appears above as comments. Use this ontology as a starting point
# for integration with ENVO or other domain ontologies. Dates and creator are illustrative.
#
# Notes:
# - Classes are arranged to reflect a natural/anthropogenic split, geological & hydrogeological hierarchy,
#   and ecosystem/habitat relationships.
# - Datatype properties (hasDepth, hasPorosity, hasArea, etc.) use xsd types.
# - Object properties (locatedIn, partOf, hasSubstrate, hasVegetationCover) connect entities.
# - Example individual provided: Ogallala_Aquifer.
#
# Copyright: example usage only.

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix env:  <http://example.org/envo-refined#> .

<> a owl:Ontology ;
   dcterms:title "Refined Environmental Ontology (ENVO-inspired)" ;
   dcterms:creator "Ontology Engineer" ;
   dcterms:created "2026-04-01"^^xsd:date ;
   dcterms:description "A refined ontology capturing environmental, geological, hydrogeological, and ecosystem concepts, including aquifers and associated properties." .

################################################################
# Classes
################################################################

env:Environment a owl:Class ;
    rdfs:label "Environment" ;
    rdfs:comment "Top-level class representing any environment, natural or anthropogenic." .

env:NaturalEnvironment a owl:Class ;
    rdfs:label "Natural environment" ;
    rdfs:subClassOf env:Environment ;
    rdfs:comment "Environments primarily shaped by natural processes." .

env:AnthropogenicEnvironment a owl:Class ;
    rdfs:label "Anthropogenic environment" ;
    rdfs:subClassOf env:Environment ;
    rdfs:comment "Environments significantly modified or created by human activity." .

env:Biome a owl:Class ;
    rdfs:label "Biome" ;
    rdfs:subClassOf env:NaturalEnvironment ;
    rdfs:comment "Major ecological community type (e.g., tundra, savanna)." .

env:Ecosystem a owl:Class ;
    rdfs:label "Ecosystem" ;
    rdfs:subClassOf env:Biome ;
    rdfs:comment "A biological community of interacting organisms and their physical environment." .

env:Habitat a owl:Class ;
    rdfs:label "Habitat" ;
    rdfs:subClassOf env:Ecosystem ;
    rdfs:comment "The specific environment in which an organism or ecological population lives." .

env:GeologicalUnit a owl:Class ;
    rdfs:label "Geological unit" ;
    rdfs:subClassOf env:NaturalEnvironment ;
    rdfs:comment "A defined volume of rock, sediment, soil, or other geologic material." .

env:HydrogeologicalFeature a owl:Class ;
    rdfs:label "Hydrogeological feature" ;
    rdfs:subClassOf env:GeologicalUnit ;
    rdfs:comment "Geological units characterized by their interaction with groundwater (e.g., aquifers, confining layers)." .

env:Aquifer a owl:Class ;
    rdfs:label "Aquifer" ;
    rdfs:subClassOf env:HydrogeologicalFeature ;
    rdfs:comment "A geological formation or group of formations capable of storing and transmitting significant quantities of groundwater." ;
    # Aquifers are expected to have a depth and porosity values (datatype properties)
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty env:hasDepth ;
        owl:someValuesFrom xsd:decimal
    ] , [
        a owl:Restriction ;
        owl:onProperty env:hasPorosity ;
        owl:someValuesFrom xsd:decimal
    ] .

env:ConfiningLayer a owl:Class ;
    rdfs:label "Confining layer" ;
    rdfs:subClassOf env:HydrogeologicalFeature ;
    rdfs:comment "Low-permeability layers that limit groundwater flow and confine aquifers." .

env:Region a owl:Class ;
    rdfs:label "Region" ;
    rdfs:subClassOf env:Environment ;
    rdfs:comment "A named geographic region or administrative area." .

env:Vegetation a owl:Class ;
    rdfs:label "Vegetation" ;
    rdfs:subClassOf env:Habitat ;
    rdfs:comment "Plant life covering an area (e.g., forest, grassland)." .

env:EnvironmentalQuality a owl:Class ;
    rdfs:label "Environmental quality" ;
    rdfs:comment "Qualities or metrics describing environmental condition (e.g., water quality, contamination status)." .

################################################################
# Object properties
################################################################

env:partOf a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:label "part of" ;
    rdfs:comment "Indicates that one entity is a (possibly proper) part of another entity." ;
    rdfs:domain env:Environment ;
    rdfs:range env:Environment .

env:hasComponent a owl:ObjectProperty ;
    rdfs:label "has component" ;
    rdfs:comment "Indicates physical components or sub-units of an environmental feature." ;
    rdfs:domain env:Environment ;
    rdfs:range env:Environment .

env:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in" ;
    rdfs:comment "Relates an entity to the region or larger environmental unit in which it is found." ;
    rdfs:domain env:Environment ;
    rdfs:range env:Region .

env:hasSubstrate a owl:ObjectProperty ;
    rdfs:label "has substrate" ;
    rdfs:comment "Relates a habitat or surface environment to its underlying geological substrate." ;
    rdfs:domain env:Habitat ;
    rdfs:range env:GeologicalUnit .

env:hasVegetationCover a owl:ObjectProperty ;
    rdfs:label "has vegetation cover" ;
    rdfs:comment "Relates an environmental area to the dominant vegetation class." ;
    rdfs:domain env:Environment ;
    rdfs:range env:Vegetation .

env:influencedBy a owl:ObjectProperty ;
    rdfs:label "influenced by" ;
    rdfs:comment "Indicates anthropogenic or natural processes influencing an environment." ;
    rdfs:domain env:Environment ;
    rdfs:range env:Environment .

env:hasQuality a owl:ObjectProperty ;
    rdfs:label "has quality" ;
    rdfs:comment "Associates an environment with environmental quality descriptors." ;
    rdfs:domain env:Environment ;
    rdfs:range env:EnvironmentalQuality .

################################################################
# Datatype properties
################################################################

env:hasDepth a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "has depth" ;
    rdfs:comment "Vertical extent (depth) of a hydrogeological feature or geological unit, in meters (use xsd:decimal)." ;
    rdfs:domain env:HydrogeologicalFeature ;
    rdfs:range xsd:decimal .

env:hasThickness a owl:DatatypeProperty ;
    rdfs:label "has thickness" ;
    rdfs:comment "Thickness of a layer or formation in meters (xsd:decimal)." ;
    rdfs:domain env:GeologicalUnit ;
    rdfs:range xsd:decimal .

env:hasPorosity a owl:DatatypeProperty ;
    rdfs:label "has porosity" ;
    rdfs:comment "Porosity value (fraction between 0 and 1) describing void fraction; use xsd:decimal." ;
    rdfs:domain env:HydrogeologicalFeature ;
    rdfs:range xsd:decimal .

env:hasHydraulicConductivity a owl:DatatypeProperty ;
    rdfs:label "has hydraulic conductivity" ;
    rdfs:comment "Hydraulic conductivity (L/T), e.g., meters per day; use xsd:decimal." ;
    rdfs:domain env:HydrogeologicalFeature ;
    rdfs:range xsd:decimal .

env:hasArea a owl:DatatypeProperty ;
    rdfs:label "has area" ;
    rdfs:comment "Horizontal area of an environment or region in square kilometers (xsd:decimal)." ;
    rdfs:domain env:Environment ;
    rdfs:range xsd:decimal .

env:hasVolume a owl:DatatypeProperty ;
    rdfs:label "has volume" ;
    rdfs:comment "Volume of a geological or hydrogeological feature in cubic meters (xsd:decimal)." ;
    rdfs:domain env:GeologicalUnit ;
    rdfs:range xsd:decimal .

env:hasTemperature a owl:DatatypeProperty ;
    rdfs:label "has temperature" ;
    rdfs:comment "Representative temperature of an environmental feature in degrees Celsius (xsd:decimal)." ;
    rdfs:domain env:Environment ;
    rdfs:range xsd:decimal .

env:hasSalinity a owl:DatatypeProperty ;
    rdfs:label "has salinity" ;
    rdfs:comment "Salinity concentration (e.g., PSU or g/kg) as a decimal." ;
    rdfs:domain env:Environment ;
    rdfs:range xsd:decimal .

################################################################
# Example restrictions and complex class definitions
################################################################

# Define "ConfinedAquifer" as an aquifer that is bounded by at least one confining layer
env:ConfinedAquifer a owl:Class ;
    rdfs:label "Confined aquifer" ;
    rdfs:subClassOf env:Aquifer ;
    rdfs:comment "An aquifer bounded above and/or below by confining layers." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty env:hasComponent ;
        owl:someValuesFrom env:ConfiningLayer
    ] .

# Define "UnconfinedAquifer" as an aquifer that is in hydraulic continuity with the surface
env:UnconfinedAquifer a owl:Class ;
    rdfs:label "Unconfined aquifer" ;
    rdfs:subClassOf env:Aquifer ;
    rdfs:comment "An aquifer with its upper surface (water table) open to the atmosphere through permeable material." ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty env:hasDepth ;
        owl:someValuesFrom xsd:decimal
    ] .

################################################################
# Example individuals (instances)
################################################################

env:Great_Plains a env:Region ;
    rdfs:label "Great Plains" ;
    rdfs:comment "A broad expanse of flat land covering parts of central North America." ;
    env:hasArea "174000"^^xsd:decimal .

env:Ogallala_Aquifer a env:UnconfinedAquifer ;
    rdfs:label "Ogallala Aquifer" ;
    rdfs:comment "A major aquifer underlying the Great Plains of the United States (example individual)." ;
    env:hasDepth "300.0"^^xsd:decimal ;            # depth in meters (example)
    env:hasPorosity "0.25"^^xsd:decimal ;         # example porosity (fraction)
    env:hasHydraulicConductivity "10.0"^^xsd:decimal ; # example units: m/day (illustrative)
    env:hasArea "450000.0"^^xsd:decimal ;         # example area in km^2 (illustrative)
    env:locatedIn env:Great_Plains ;
    env:hasQuality [
        a env:EnvironmentalQuality ;
        rdfs:label "Variable groundwater quality" ;
        rdfs:comment "Groundwater quality varies spatially and temporally across the aquifer."
    ] .

env:Grassland a env:Vegetation ;
    rdfs:label "Grassland" ;
    rdfs:comment "Dominant vegetation type composed of grasses and herbaceous plants." .

# Connect habitat to substrate example
env:Prairie_Habitat a env:Habitat ;
    rdfs:label "Prairie habitat" ;
    env:hasSubstrate env:Ogallala_Aquifer ;
    env:hasVegetationCover env:Grassland ;
    rdfs:comment "Example habitat above an aquifer, illustrating hasSubstrate and hasVegetationCover relations." .

################################################################
# SKOS concept examples for controlled terms (optional)
################################################################

env:porosityConcept a skos:Concept ;
    skos:prefLabel "Porosity" ;
    skos:definition "The proportion of void (empty) space in a material, expressed as a fraction or percentage." .

env:hydraulicConductivityConcept a skos:Concept ;
    skos:prefLabel "Hydraulic conductivity" ;
    skos:definition "A measure of a material's ability to transmit water." .

################################################################
# End of ontology
################################################################