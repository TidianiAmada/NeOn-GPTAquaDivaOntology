@prefix : <http://example.org/aquadiva#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:AbioticFactor a rdfs:Class ;
    rdfs:label "Abiotic Factor" ;
    rdfs:comment "Non-living chemical and physical parts of the environment that affect living organisms and the functioning of ecosystems." .

:AgriculturalActivity a rdfs:Class ;
    rdfs:label "Agricultural Activity" ;
    rdfs:comment "Farming practices and operations that can impact environmental quality, including groundwater systems, through the use of fertilizers, pesticides, and water management." .

:AgriculturalPractice a rdfs:Class ;
    rdfs:label "Agricultural Practice" ;
    rdfs:comment "Methods and techniques employed in cultivation and livestock rearing, which impact environmental quality and productivity." .

:AnalysisMethod a rdfs:Class ;
    rdfs:label "Analysis Method" ;
    rdfs:comment "Techniques used to examine samples in order to discover their composition, structure, or properties, often used in scientific research." .

:AquiferChemistry a rdfs:Class ;
    rdfs:label "Aquifer Chemistry" ;
    rdfs:comment "Chemical characteristics and processes occurring within an aquifer, including solute transport and reactions." .

:AquiferSystem a rdfs:Class ;
    rdfs:label "Aquifer System" ;
    rdfs:comment "An underground layer of water-bearing permeable rock or materials such as gravel, sand, or silt." .

:Biodiversity a rdfs:Class ;
    rdfs:label "Biodiversity" ;
    rdfs:comment "The variety and variability of life forms within a given ecosystem, region, or on the entire Earth, important in assessing the health and function of ecosystems." .

:BioticFactor a rdfs:Class ;
    rdfs:label "Biotic Factor" ;
    rdfs:comment "A living element of an ecosystem that influences or interacts with other organisms and the environment, such as plants, animals, and microorganisms." .

:Bioturbation a rdfs:Class ;
    rdfs:label "Bioturbation" ;
    rdfs:comment "The disturbance of sedimentary deposits by living organisms, often affecting soil composition and structure." .

:CO2FixationPathway a rdfs:Class ;
    rdfs:label "CO2 Fixation Pathway" ;
    rdfs:comment "Biochemical routes by which CO2 is converted into organic molecules by living organisms, crucial for carbon cycling and storage." .

:CarbonateDissolution a rdfs:Class ;
    rdfs:label "Carbonate Dissolution" ;
    rdfs:comment "A process where carbonate minerals (e.g., calcite, dolomite) dissolve in water, significantly affecting karst aquifer systems." .

:CatchmentArea a rdfs:Class ;
    rdfs:label "Catchment Area" ;
    rdfs:comment "The area from which rainfall and surface water flow into a particular river, lake, or reservoir." .

:ChemicalCompound a rdfs:Class ;
    rdfs:label "Chemical Compound" ;
    rdfs:comment "A substance consisting of two or more different elements chemically bonded together, found in groundwater." .

:Consumption a rdfs:Class ;
    rdfs:label "Consumption" ;
    rdfs:comment "The use or depletion of resources or energy, commonly in biological contexts such as metabolism or ecological interactions." .

:DOM a rdfs:Class ;
    rdfs:label "DOM" ;
    rdfs:comment "Dissolved organic matter in water, which includes a complex mixture of organic compounds that affects water chemistry and microbial activity." .

:EnergyMetabolismPathway a rdfs:Class ;
    rdfs:label "Energy Metabolism Pathway" ;
    rdfs:comment "Biochemical routes by which organisms transform energy from one form to another, crucial for cellular processes and ecological dynamics." .

:EnvironmentalSignal a rdfs:Class ;
    rdfs:label "Environmental Signal" ;
    rdfs:comment "Natural or anthropogenic indicators that provide information about environmental conditions or changes, used for monitoring and management purposes." .

:ForestEcosystem a rdfs:Class ;
    rdfs:label "Forest Ecosystem" ;
    rdfs:comment "An ecological system within a forest setting, encompassing the interactions among plants, animals, microorganisms, and their environment." .

:FracturedRock a rdfs:Class ;
    rdfs:label "Fractured Rock" ;
    rdfs:comment "Rock formations that have significant fracture systems, influencing groundwater flow and storage." .

:GeologicalStrata a rdfs:Class ;
    rdfs:label "Geological Strata" ;
    rdfs:comment "Layers of sedimentary rock or soil with consistent characteristics that can influence groundwater movement and storage." .

:Groundwater a rdfs:Class ;
    rdfs:label "Groundwater" ;
    rdfs:comment "Water located beneath the earth's surface in soil pore spaces and in the fractures of rock formations." .

:GroundwaterChemistry a rdfs:Class ;
    rdfs:label "Groundwater Chemistry" ;
    rdfs:comment "The chemical composition and properties of groundwater, including solutes and gases, which affect its quality and ecological role." .

:GroundwaterContamination a rdfs:Class ;
    rdfs:label "Groundwater Contamination" ;
    rdfs:comment "The presence of harmful substances in groundwater, which can compromise water quality and ecosystem health." .

:GroundwaterEcosystem a rdfs:Class ;
    rdfs:label "Groundwater Ecosystem" ;
    rdfs:comment "An ecological system located below the earth's surface, encompassing interactions among water, microorganisms, chemicals, and geological materials." .

:GroundwaterFlow a rdfs:Class ;
    rdfs:label "Groundwater Flow" ;
    rdfs:comment "The movement of water through aquifer systems, driven by gradients in pressure and elevation, crucial for water supply and ecosystem support." .

:GroundwaterPrecipitation a rdfs:Class ;
    rdfs:label "Groundwater Precipitation" ;
    rdfs:comment "The process where water precipitates, either through chemical means within groundwater systems or as a part of the hydrological cycle impacting groundwater recharge." .

:GroundwaterQuality a rdfs:Class ;
    rdfs:label "Groundwater Quality" ;
    rdfs:comment "The condition of groundwater, often assessed by chemical, physical, and biological parameters to determine suitability for use." .

:GroundwaterVulnerability a rdfs:Class ;
    rdfs:label "Groundwater Vulnerability" ;
    rdfs:comment "The susceptibility of groundwater to contamination, influenced by geological, hydrological, and chemical factors." .

:HainichCriticalZone a rdfs:Class ;
    rdfs:label "Hainich Critical Zone" ;
    rdfs:comment "A specific geographic area used for studying the critical zone, which includes the earth's outer skin where interactions occur between the lithosphere, atmosphere, hydrosphere, and biosphere." .

:HydraulicProperty a rdfs:Class ;
    rdfs:label "Hydraulic Property" ;
    rdfs:comment "Properties of materials related to the movement and storage of fluids, particularly water, essential in hydrogeology and civil engineering." .

:HydrogeochemicalCharacterizationMethod a rdfs:Class ;
    rdfs:label "Hydrogeochemical Characterization Method" ;
    rdfs:comment "Techniques used to assess the chemical properties and interactions in groundwater systems, important for understanding water quality and geological impacts." .

:HydrologicalProperty a rdfs:Class ;
    rdfs:label "Hydrological Property" ;
    rdfs:comment "Characteristics of the movement, distribution, and quality of water through the Earth's atmosphere and surface, key to understanding hydrological cycles and systems." .

:InfiltrationArea a rdfs:Class ;
    rdfs:label "Infiltration Area" ;
    rdfs:comment "Areas of land where water permeates the soil surface to enter an aquifer, significantly impacting groundwater recharge and quality." .

:KarstAquifer a rdfs:Class ;
    rdfs:label "Karst Aquifer" ;
    rdfs:comment "A type of aquifer characterized by soluble rock layers like limestone, leading to distinctive topographies and hydrology due to dissolution and water flow." .

:KarstSystem a rdfs:Class ;
    rdfs:label "Karst System" ;
    rdfs:comment "A geological system formed from the dissolution of soluble rocks including limestone, dolomite, and gypsum, characterized by sinkholes, caves, and underground drainage." .

:Karstification a rdfs:Class ;
    rdfs:label "Karstification" ;
    rdfs:comment "The process of creating karst landscapes through the dissolution of soluble rocks, leading to features like caves and underground rivers." .

:LimestoneAquifer a rdfs:Class ;
    rdfs:label "Limestone Aquifer" ;
    rdfs:comment "An aquifer consisting predominantly of limestone, which is highly permeable due to the presence of dissolution-formed conduits." .

:ManagementPractice a rdfs:Class ;
    rdfs:label "Management Practice" ;
    rdfs:comment "Approaches and techniques used in managing natural resources and environmental quality, including water resources." .

:MarinePhage a rdfs:Class ;
    rdfs:label "Marine Phage" ;
    rdfs:comment "Viruses that infect marine bacteria, playing roles in marine ecosystems by influencing bacterial populations and nutrient cycles." .

:Microbes a rdfs:Class ;
    rdfs:label "Microbes" ;
    rdfs:comment "Organisms that are microscopic, such as bacteria, archaea, and certain fungi, present in the aquifer systems." .

:MicrobialCommunity a rdfs:Class ;
    rdfs:label "Microbial Community" ;
    rdfs:comment "A community of microorganisms, including bacteria, fungi, and viruses, living in a shared environment, influencing ecological processes and cycles." .

:MicrobialDynamics a rdfs:Class ;
    rdfs:label "Microbial Dynamics" ;
    rdfs:comment "Changes and interactions among microbial populations within an environment, often influenced by physical and chemical conditions." .

:MicrobialFunctionalGuilds a rdfs:Class ;
    rdfs:label "Microbial Functional Guilds" ;
    rdfs:comment "Groups of microorganisms categorized by their metabolic or functional roles within ecological communities." .

:MicrobialMechanism a rdfs:Class ;
    rdfs:label "Microbial Mechanism" ;
    rdfs:comment "Mechanisms or processes employed by microorganisms to interact with their environment, affecting ecological balances and nutrient cycles." .

:Mineral a rdfs:Class ;
    rdfs:label "Mineral" ;
    rdfs:comment "Naturally occurring inorganic substances with a definite chemical composition and physical properties that are part of the earth's crust." .

:Miz a rdfs:Class ;
    rdfs:label "Miz" ;
    rdfs:comment "A specific type of organic or chemical marker used in studies of environmental samples to track changes or origins of substances." .

:MobileOrganicMatter a rdfs:Class ;
    rdfs:label "Mobile Organic Matter" ;
    rdfs:comment "Organic materials within the groundwater that are mobile and can transport nutrients or pollutants." .

:MolecularFormula a rdfs:Class ;
    rdfs:label "Molecular Formula" ;
    rdfs:comment "A representation of the number and type of atoms in a molecule, providing essential information about chemical structures in environmental studies." .

:MolecularMarker a rdfs:Class ;
    rdfs:label "Molecular Marker" ;
    rdfs:comment "Biomolecules used as markers to identify and track genetic material, species identification, or processes within ecosystems." .

:MultilevelGroundwaterSystem a rdfs:Class ;
    rdfs:label "Multilevel Groundwater System" ;
    rdfs:comment "A groundwater system that includes multiple aquifer layers, often interconnected, allowing for complex flow and solute transport dynamics." .

:MuschelkalkFormation a rdfs:Class ;
    rdfs:label "Muschelkalk Formation" ;
    rdfs:comment "A geological formation consisting mainly of middle Triassic limestone, known for its distinct sedimentary characteristics." .

:NitrogenCycle a rdfs:Class ;
    rdfs:label "Nitrogen Cycle" ;
    rdfs:comment "The series of processes by which nitrogen is converted into its various chemical forms, crucial for life on Earth." .

:NitrogenTransformation a rdfs:Class ;
    rdfs:label "Nitrogen Transformation" ;
    rdfs:comment "Biochemical processes that convert nitrogen into various chemical forms, critical in nutrient cycling and ecological balance." .

:OrganicGroundwaterComponent a rdfs:Class ;
    rdfs:label "Organic Groundwater Component" ;
    rdfs:comment "Organic substances found in groundwater, including both naturally occurring compounds and contaminants." .

:Permeability a rdfs:Class ;
    rdfs:label "Permeability" ;
    rdfs:comment "A measure of the ability of a material (such as soil or rock) to allow fluids to pass through it, crucial for assessing aquifer recharge and water movement." .

:Production a rdfs:Class ;
    rdfs:label "Production" ;
    rdfs:comment "The creation or manufacture of substances or materials, often used in the context of biological or chemical processes in environmental systems." .

:RareSpeciesBiodiversity a rdfs:Class ;
    rdfs:label "Rare Species Biodiversity" ;
    rdfs:comment "The presence and roles of rare species within an ecosystem, which can be indicators of environmental health and stability." .

:RockType a rdfs:Class ;
    rdfs:label "Rock Type" ;
    rdfs:comment "Categories of rocks based on their origin, texture, and mineral composition that influence geological and hydrological properties." .

:SamplingMethod a rdfs:Class ;
    rdfs:label "Sampling Method" ;
    rdfs:comment "Techniques used to collect samples from environmental media (water, soil, air) for analysis or study." .

:SeasonalVariation a rdfs:Class ;
    rdfs:label "Seasonal Variation" ;
    rdfs:comment "Changes in environmental conditions or processes that occur on a seasonal cycle, affecting ecosystems and biological responses." .

:SoilChemistry a rdfs:Class ;
    rdfs:label "Soil Chemistry" ;
    rdfs:comment "The study of the chemical characteristics and processes of soil, including nutrient content, pH, and contaminant levels." .

:SoilGroundwaterInteraction a rdfs:Class ;
    rdfs:label "Soil Groundwater Interaction" ;
    rdfs:comment "The processes and relationships between soil characteristics and groundwater movement and quality, key for managing water resources and ecological health." .

:SoilOrganicMatter a rdfs:Class ;
    rdfs:label "Soil Organic Matter" ;
    rdfs:comment "Organic materials in soil, including decomposed plant and animal residues, which influence soil fertility, structure, and function." .

:SoilTracerStudy a rdfs:Class ;
    rdfs:label "Soil Tracer Study" ;
    rdfs:comment "Research studies that use tracers to analyze soil properties, such as permeability and solute transport, to better understand soil-water interactions." .

:SoilWaterContent a rdfs:Class ;
    rdfs:label "Soil Water Content" ;
    rdfs:comment "The amount of water contained within the soil, crucial for understanding soil health, plant growth, and hydrological processes." .

:SpatialPattern a rdfs:Class ;
    rdfs:label "Spatial Pattern" ;
    rdfs:comment "The arrangement or distribution of particular phenomena or entities in physical space, significant in studies of ecology and geographical sciences." .

:TemporalPattern a rdfs:Class ;
    rdfs:label "Temporal Pattern" ;
    rdfs:comment "The distribution of events or phenomena over time, relevant in ecological, geological, and climatological studies." .

:Terrain a rdfs:Class ;
    rdfs:label "Terrain" ;
    rdfs:comment "The physical landscape including its elevation, slope, and orientation, which influences water flow and ecological conditions." .

:TraceGas a rdfs:Class ;
    rdfs:label "Trace Gas" ;
    rdfs:comment "Gases present in small amounts in the atmosphere, significant for their roles in chemical processes and climate dynamics." .

:TriassicAquifer a rdfs:Class ;
    rdfs:label "Triassic Aquifer" ;
    rdfs:comment "An aquifer system formed during the Triassic period, often characterized by specific sedimentary rock formations." .

:Vegetation a rdfs:Class ;
    rdfs:label "Vegetation" ;
    rdfs:comment "Plants and trees that cover a portion of the earth's surface, influencing ecological balances and processes including hydrology." .

:VegetationCover a rdfs:Class ;
    rdfs:label "Vegetation Cover" ;
    rdfs:comment "The layer of vegetation that covers a portion of the earth's surface, providing habitat, regulating water flow, and influencing climate." .

:VegetationType a rdfs:Class ;
    rdfs:label "Vegetation Type" ;
    rdfs:comment "Categories of vegetation defined by the plant species composition, often associated with specific climatic, geographical, or ecological conditions." .

:WaterFlow a rdfs:Class ;
    rdfs:label "Water Flow" ;
    rdfs:comment "The flow of water within various environments, including rivers, aquifers, and engineered channels, vital for ecological and human activities." .

<http://example.org/aquadiva> a owl:Ontology ;
    dct:description "An ontology for integrating and annotating diverse datasets in groundwater ecosystems research, covering hydrogeology, microbial ecology, geochemistry, and karst systems."@en ;
    dct:title "AquaDiva Ontology" ;
    owl:versionInfo "1.0" .

:AmazonRainforestSoil a :SoilGroundwaterInteraction ;
    rdfs:comment "Soil from the Amazon rainforest, interacting strongly with groundwater through dense vegetation and frequent rainfall." .

:AquaticMicrobialCommunity a :MicrobialCommunity ;
    rdfs:comment "A community of diverse microorganisms found in aquatic environments, often within groundwater ecosystems." .

:AquiferFungiSample a :Fungi ;
    rdfs:comment "A sample of fungi collected from an aquifer, representing the fungal biodiversity within groundwater ecosystems." .

:CO2ReductionPathway a :CO2FixationPathway ;
    rdfs:comment "A biochemical pathway involved in reducing CO2 into organic compounds, significant in microbial metabolic processes." .

:ChalkAquifer a :LimestoneAquifer ;
    rdfs:comment "An aquifer consisting of chalk, particularly permeable and capable of storing significant volumes of water." .

:ContaminatedSite a :GroundwaterContamination ;
    rdfs:comment "A location where groundwater has been adversely affected by pollutants, potentially harmful to ecosystems and human health." .

:DeepAquifer a :AquiferSystem ;
    rdfs:comment "A deep-seated aquifer, often less susceptible to surface contamination but crucial for providing long-term water supply." .

:DesertSpring a :Groundwater ;
    rdfs:comment "A spring located in a desert region, providing critical water resources for local ecosystems and human populations." .

:ForestMicrohabitat a :MicrobialCommunity ;
    rdfs:comment "A microbial community within a forest setting, influenced by the organic matter and moisture conditions of the forest floor." .

:FracturedRockAquifer a :GroundwaterQuality ;
    rdfs:comment "An aquifer influenced by fractured rock formations, affecting the water quality due to increased flow and potential contamination paths." .

:HainichCZObservatory a :HainichCriticalZone ;
    rdfs:comment "A research observatory in the Hainich region focusing on the critical zone, studying interactions within the subsurface biosphere and hydrosphere." .

:HighCalciumWater a :Groundwater ;
    rdfs:comment "Groundwater with a high concentration of calcium, typically found in limestone aquifers." .

:HydraulicConductivityStudy a :HydrogeochemicalCharacterizationMethod ;
    rdfs:comment "A study measuring the rate at which water can pass through aquifer materials, essential for understanding groundwater flow dynamics." .

:IndustrialAgricultureArea a :AgriculturalActivity ;
    rdfs:comment "A region dominated by industrial-scale agriculture, often impacting local groundwater systems through chemical runoff and high water usage." .

:KarstAquiferSystem a :KarstAquifer ;
    rdfs:comment "An aquifer system within a karst landscape characterized by soluble rocks and underground drainage systems." .

:KarstSpringWater a :Groundwater ;
    rdfs:comment "Water emerging from a karst spring, typically clear and filtered through limestone, but vulnerable to rapid contamination due to minimal filtration." .

:NitrateRichWater a :Groundwater ;
    rdfs:comment "Groundwater characterized by high nitrate levels, often a result of agricultural runoff or inadequate waste management practices." .

:PhosphateMinerals a :Mineral ;
    rdfs:comment "Minerals containing phosphate, significant for their role in geochemical cycles and as indicators of mineral wealth." .

:RechargeZone a :InfiltrationArea ;
    rdfs:comment "An area critical for the recharge of groundwater, where surface water is efficiently absorbed into the subsurface aquifer." .

:SeasonalWetland a :GroundwaterPrecipitation ;
    rdfs:comment "A wetland area that experiences seasonal fluctuations in groundwater levels, affecting local biodiversity and hydrological dynamics." .

:SubsurfaceBacterialCulture a :Microbes ;
    rdfs:comment "Cultures of bacteria isolated from subsurface environments, studied for their ecological roles and adaptations to low-nutrient conditions." .

:TriassicLimestone a :GeologicalFormation ;
    rdfs:comment "A specific limestone formation that originates from the Triassic period, typically porous and water-permeable." .

:adaptsTo a rdf:Property ;
    rdfs:label "adapts to" ;
    rdfs:comment "Indicates the conditions or environments to which an entity adjusts or modifies itself." ;
    rdfs:inverseOf :adaptTo .

:existsIn a rdf:Property,
        owl:FunctionalProperty ;
    rdfs:label "exists in" ;
    rdfs:comment "Denotes the presence or occurrence of an entity within a particular environment or context.",
        "Indicates the environment or context within which an entity is present or occurs." ;
    rdfs:inverseOf :existIn .

:hasAnnualRainfall a owl:DatatypeProperty ;
    rdfs:label "has annual rainfall" ;
    rdfs:domain :GroundwaterPrecipitation ;
    rdfs:range xsd:float .

:hasAquiferDepth a owl:DatatypeProperty ;
    rdfs:label "has aquifer depth" ;
    rdfs:domain :AquiferSystem ;
    rdfs:range xsd:float .

:hasBiodiversityIndex a owl:DatatypeProperty ;
    rdfs:label "has biodiversity index" ;
    rdfs:domain :Biodiversity ;
    rdfs:range xsd:float .

:hasCO2EmissionRate a owl:DatatypeProperty ;
    rdfs:label "has CO2 emission rate" ;
    rdfs:domain :GroundwaterEcosystem ;
    rdfs:range xsd:float .

:hasChemicalConcentration a owl:DatatypeProperty ;
    rdfs:label "has chemical concentration" ;
    rdfs:domain :Groundwater ;
    rdfs:range xsd:float .

:hasComponents a rdf:Property ;
    rdfs:label "has components" ;
    rdfs:comment "Indicates the parts or components that make up an entity." ;
    rdfs:domain :HainichCriticalZone ;
    rdfs:inverseOf :hasComponent ;
    rdfs:range :MicrobialDynamics .

:hasInfiltrationRate a owl:DatatypeProperty ;
    rdfs:label "has infiltration rate" ;
    rdfs:domain :InfiltrationArea ;
    rdfs:range xsd:float .

:hasManagementEffectivenessScore a owl:DatatypeProperty ;
    rdfs:label "has management effectiveness score" ;
    rdfs:domain :ManagementPractice ;
    rdfs:range xsd:float .

:hasMicrobialDensity a owl:DatatypeProperty ;
    rdfs:label "has microbial density" ;
    rdfs:domain :Microbes ;
    rdfs:range xsd:positiveInteger .

:hasMineralDensity a owl:DatatypeProperty ;
    rdfs:label "has mineral density" ;
    rdfs:domain :Mineral ;
    rdfs:range xsd:float .

:hasNitrogenLevel a owl:DatatypeProperty ;
    rdfs:label "has nitrogen level" ;
    rdfs:domain :NitrogenCycle ;
    rdfs:range xsd:float .

:hasOrganicMatterContent a owl:DatatypeProperty ;
    rdfs:label "has organic matter content" ;
    rdfs:domain :SoilOrganicMatter ;
    rdfs:range xsd:percentage .

:hasPHLevel a owl:DatatypeProperty ;
    rdfs:label "has pH level" ;
    rdfs:domain :GroundwaterChemistry ;
    rdfs:range xsd:float .

:hasPermeabilityIndex a owl:DatatypeProperty ;
    rdfs:label "has permeability index" ;
    rdfs:domain :Permeability ;
    rdfs:range xsd:float .

:hasPollutionLevel a owl:DatatypeProperty ;
    rdfs:label "has pollution level" ;
    rdfs:domain :GroundwaterContamination ;
    rdfs:range xsd:float .

:hasRockPorosity a owl:DatatypeProperty ;
    rdfs:label "has rock porosity" ;
    rdfs:domain :RockType ;
    rdfs:range xsd:decimal .

:hasRoleIn a rdf:Property ;
    rdfs:label "has role in" ;
    rdfs:comment "Indicates the context or system within which an entity plays a part or function." ;
    rdfs:inverseOf :playRoleIn .

:hasSoilMoistureContent a owl:DatatypeProperty ;
    rdfs:label "has soil moisture content" ;
    rdfs:domain :SoilChemistry ;
    rdfs:range xsd:percentage .

:hasSpeciesCount a owl:DatatypeProperty ;
    rdfs:label "has species count" ;
    rdfs:domain :RareSpeciesBiodiversity ;
    rdfs:range xsd:positiveInteger .

:hasTemperature a owl:DatatypeProperty ;
    rdfs:label "has temperature" ;
    rdfs:domain :Groundwater ;
    rdfs:range xsd:decimal .

:hasTraceGasConcentration a owl:DatatypeProperty ;
    rdfs:label "has trace gas concentration" ;
    rdfs:domain :TraceGas ;
    rdfs:range xsd:float .

:hasVegetationDensity a owl:DatatypeProperty ;
    rdfs:label "has vegetation density" ;
    rdfs:domain :Vegetation ;
    rdfs:range xsd:positiveInteger .

:hasWaterFlowSpeed a owl:DatatypeProperty ;
    rdfs:label "has water flow speed" ;
    rdfs:domain :WaterFlow ;
    rdfs:range xsd:float .

:impacts a rdf:Property ;
    rdfs:label "impacts" ;
    rdfs:comment "Indicates the entity that experiences a strong effect or influence from another, often in contexts involving environmental impact or change." ;
    rdfs:inverseOf :impact .

:interactsWith a rdf:Property,
        owl:ReflexiveProperty ;
    rdfs:label "interacts with" ;
    rdfs:comment "Indicates mutual or reciprocal action or influence between entities, typically within ecological or chemical contexts." ;
    rdfs:domain :OrganicGroundwaterComponent ;
    rdfs:inverseOf :interactWith ;
    rdfs:range :Mineral,
        :RockType .

:isAffected a rdf:Property,
        owl:ReflexiveProperty ;
    rdfs:label "is affected" ;
    rdfs:comment "Indicates that an entity is influenced or altered by another, often in ecological or chemical contexts." ;
    rdfs:inverseOf :affect .

:isAffectedBy a rdf:Property,
        owl:TransitiveProperty ;
    rdfs:label "is affected by" ;
    rdfs:comment "Indicates the factors or conditions that impact or modify an entity." ;
    rdfs:domain :FracturedRock,
        :KarstSystem ;
    rdfs:inverseOf :affectedBy ;
    rdfs:range :GroundwaterQuality .

:isAssociatedWith a rdf:Property,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is associated with" ;
    rdfs:comment "Indicates that two entities are connected or related, typically within ecological or geological contexts." ;
    rdfs:domain :GroundwaterPrecipitation ;
    rdfs:inverseOf :associatedWith ;
    rdfs:range :GeologicalStrata .

:isCharacterizedBy a rdf:Property ;
    rdfs:label "is characterized by" ;
    rdfs:comment "Indicates the entity that exhibits specific characteristics or properties." ;
    rdfs:inverseOf :hasCharacteristic .

:isDefinedBy a rdf:Property ;
    rdfs:label "is defined by" ;
    rdfs:comment "Indicates the entity or area whose characteristics or boundaries are specified or determined." ;
    rdfs:domain :Aquifer ;
    rdfs:inverseOf :define ;
    rdfs:range :CatchmentArea,
        :InfiltrationArea .

:isDetectedThrough a rdf:Property ;
    rdfs:label "is detected through" ;
    rdfs:comment "Indicates the method or means by which something is identified or recognized, often in analytical or observational contexts." ;
    rdfs:inverseOf :detectedThrough .

:isFoundIn a rdf:Property ;
    rdfs:label "is found in" ;
    rdfs:comment "Indicates the aquifer system where specific microbes or chemicals can be found." ;
    rdfs:domain :AquiferSystem ;
    rdfs:inverseOf :foundIn ;
    rdfs:range :Microbes .

:isIndicatedBy a rdf:Property ;
    rdfs:label "is indicated by" ;
    rdfs:comment "Indicates the entity that signals or represents another entity, often in contexts involving markers or indicators." ;
    rdfs:inverseOf :indicate .

:isInfluenced a rdf:Property,
        owl:ReflexiveProperty ;
    rdfs:label "is influenced" ;
    rdfs:comment "Indicates the entity that affects or shapes another, typically in contexts involving environmental or biological factors." ;
    rdfs:inverseOf :influencedBy .

:isInfluencedBy a rdf:Property ;
    rdfs:label "is influenced by" ;
    rdfs:comment "Indicates that an entity is affected or altered by another entity's action or presence." ;
    rdfs:domain :AquiferChemistry ;
    rdfs:inverseOf :influence ;
    rdfs:range :MicrobialFunctionalGuilds .

:isInvolvedIn a rdf:Property ;
    rdfs:label "is involved in" ;
    rdfs:comment "Indicates the process, activity, or context in which an entity participates or is included." ;
    rdfs:inverseOf :involvedIn .

:isPhaseOf a rdf:Property ;
    rdfs:label "is phase of" ;
    rdfs:comment "Indicates the entity that is experiencing a particular stage or phase." ;
    rdfs:domain :HainichCriticalZone ;
    rdfs:inverseOf :hasPhase ;
    rdfs:range :MicrobialDynamics .

:isRelatedTo a rdf:Property,
        owl:ReflexiveProperty,
        owl:SymmetricProperty ;
    rdfs:label "is related to" ;
